# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/shop_management

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ──────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or pick an existing one)
# 3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorised redirect URI: http://localhost:8000/api/auth/google/callback
#    (use your real domain in production, e.g. https://yourdomain.com/api/auth/google/callback)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────
# Where the callback should send the user after login
FRONTEND_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
